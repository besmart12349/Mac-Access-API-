# ── Mac Access API — Configuration ──────────────────────────────────────────
# Copy this file to .env and fill in your values.

# REQUIRED: Set a strong random API key (min 32 chars recommended)
# Generate one with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
MAC_ACCESS_API_KEY=change-me-now

# Server binding (default: localhost only — set 0.0.0.0 only if behind a tunnel/VPN)
MAC_ACCESS_HOST=127.0.0.1
MAC_ACCESS_PORT=8787

# Paths the API is allowed to read/write (comma-separated)
MAC_ACCESS_ALLOWED_PATHS=/Users,/tmp

# Command timeout in seconds
MAC_ACCESS_CMD_TIMEOUT=20

# Schedule lock (set to true to restrict API to certain hours)
MAC_ACCESS_SCHEDULE_ENABLED=false
MAC_ACCESS_SCHEDULE_START_HOUR=0
MAC_ACCESS_SCHEDULE_END_HOUR=23
MAC_ACCESS_SCHEDULE_TZ=America/New_York

# Kill switch file path
MAC_ACCESS_KILL_SWITCH_FILE=~/.mac_access_api.kill

# Max file read/write size in bytes (default 10MB)
MAC_ACCESS_MAX_FILE_BYTES=10485760

# Comma-separated command substrings to block
MAC_ACCESS_CMD_BLOCKLIST=rm -rf /,:(){ :|:& };:,curl|bash,wget|bash,mkfs
